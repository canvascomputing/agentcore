{
  "type": "object",
  "properties": {
    "line": {
      "type": "integer",
      "description": "1-based line number where the issue is"
    },
    "severity": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "category": {
      "type": "string",
      "description": "Short tag, e.g. 'unsafe-block'"
    },
    "message": {
      "type": "string",
      "description": "One sentence: what is wrong and why"
    }
  },
  "required": ["line", "severity", "category", "message"]
}
